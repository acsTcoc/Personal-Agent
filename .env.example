# Copy this file to .env for local testing. In GitHub Actions, set these
# same names as repository secrets/variables instead (Settings > Secrets
# and variables > Actions) -- never commit a real .env file.

ANTHROPIC_API_KEY=

ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

JOB_KEYWORDS=software engineering intern, data analyst intern
JOB_LOCATION=remote
JOB_EXCLUDE=staffing,recruiting agency
REMOTE_ONLY=false

AUTO_DRAFT_APPLICATIONS=true
AUTO_SEND_EMAILS=false

RESUME_PATH=data/resume.txt

# Only needed for local testing -- inside Actions this is provided automatically
GITHUB_TOKEN=
GITHUB_REPOSITORY=yourusername/uni-agent

# Only needed once you wire up gmail_helper.py
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
